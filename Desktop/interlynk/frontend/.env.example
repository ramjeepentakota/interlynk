# Backend API URL
VITE_API_URL=http://localhost:8082

# Optional: Enable debug mode
VITE_DEBUG=false

# ── TURN server (voice/video calls over the peer-to-peer WebRTC path) ──────────
# Public STUN alone only connects peers on cooperative networks. Crossing most
# real NATs/firewalls (symmetric NAT, corporate networks) REQUIRES a TURN relay,
# or calls end in "Peer connection failed. Check network/firewall." and carry no
# audio/video. Point these at your TURN server (e.g. self-hosted coturn, Twilio,
# Metered, Cloudflare). Comma-separate multiple URLs; prefer turns: (TLS/443) so
# the relay also works behind firewalls that only allow HTTPS egress.
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
