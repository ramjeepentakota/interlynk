# Backend API URL
VITE_API_URL=http://localhost:8082

# Optional: Enable debug mode
VITE_DEBUG=false

# ── TURN server (voice channels + 1-on-1 calls, both peer-to-peer WebRTC) ──────
# Public STUN alone only connects peers on cooperative networks. Crossing most
# real NATs/firewalls (symmetric NAT, corporate networks) REQUIRES a TURN relay,
# or connections end in "Peer connection failed" and carry no audio/video.
# Run the bundled free coturn relay (see infra/coturn/README.md) and point these
# at it. Comma-separate multiple URLs; prefer turns: (TLS/443) so the relay also
# works behind firewalls that only allow HTTPS egress.
# Example (after starting infra/coturn):
#   VITE_TURN_URLS=turn:192.168.1.50:3478
#   VITE_TURN_USERNAME=interlynk
#   VITE_TURN_CREDENTIAL=CHANGE_ME_TURN_PASSWORD
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
