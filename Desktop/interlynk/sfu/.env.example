# ── Narada SFU configuration ────────────────────────────────────────────────
# Copy to .env and fill in. The two that MUST be correct per environment are
# SFU_ANNOUNCED_IP and SFU_JWT_SECRET.

# Signaling HTTP/Socket.IO port (browser connects here).
SFU_PORT=4443
SFU_HOST=0.0.0.0

# Shared HMAC secret with the Spring backend (must be IDENTICAL on both sides).
# Generate a long random string, e.g.: openssl rand -hex 32
SFU_JWT_SECRET=change-me-shared-with-spring

# Public IP browsers use to reach this server (ICE announced address).
#   - Localhost dev: 127.0.0.1
#   - Hostinger VPS: your server's PUBLIC IPv4
SFU_ANNOUNCED_IP=127.0.0.1
# Interface to bind media on (0.0.0.0 = all). Usually leave as-is.
SFU_LISTEN_IP=0.0.0.0

# RTC media UDP/TCP port range — OPEN THIS RANGE ON THE VPS FIREWALL.
SFU_RTC_MIN_PORT=40000
SFU_RTC_MAX_PORT=40100

# Allowed Socket.IO CORS origins (comma-separated). Lock to your real origin in
# production, e.g. https://narada.example.com . The JWT is what authorizes joins.
SFU_CORS_ORIGINS=*

# Per-room participant cap (product target is 20).
SFU_MAX_PEERS_PER_ROOM=24

# One worker per CPU core by default; override if needed.
# SFU_NUM_WORKERS=4

# mediasoup worker log level: debug | warn | error | none
SFU_LOG_LEVEL=warn
