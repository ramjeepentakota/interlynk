@echo off
REM ── Local secrets template ──────────────────────────────────────────────────
REM Copy this file to env.local.bat and fill in real values. env.local.bat is
REM gitignored so secrets never enter version control. start.bat loads it.

set DB_USERNAME=root
set DB_PASSWORD=change-me

REM Long random 256-bit string. Generate one and keep it stable per environment.
set JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes

REM Initial admin password (first DB init only). Change after first login.
set ADMIN_INITIAL_PASSWORD=change-me

REM Seed throwaway demo/jay test accounts. Keep false outside local dev.
set SEED_DEMO_USERS=false
